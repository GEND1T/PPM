{
  "version": 2,
  "builds": [
    {
      "src": "src/app.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/src/app.js"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/cron/rekap-harian",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/v1/cron/rekap-mingguan",
      "schedule": "0 23 * * 6"
    }
  ]
}
